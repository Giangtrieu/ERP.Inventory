@model ErrorViewModel
@{
    ViewData["Title"] = "System Error";
}

<h1 class="text-danger">System error</h1>
<h2 class="text-danger">B34G Warehouse ERP could not complete your request.</h2>

@if (Model?.ShowRequestId ?? false)
{
    <p>
        <strong>Request ID:</strong> <code>@Model?.RequestId</code>
    </p>
}

<h3>Development mode</h3>
<p>
    Switching to <strong>Development</strong> will display more detailed diagnostic information.
</p>
<p>
    <strong>Do not enable Development in production.</strong>
    It can expose sensitive exception details to end users.
</p>
