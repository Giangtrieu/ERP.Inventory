@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    Layout = null;
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="request-verification-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    <title>ERP Inventory Management</title>
    <link href="~/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/css/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/assets/css/css2.css" rel="stylesheet" />
    <link href="~/erp/app.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar" id="sidebar">
            <div class="brand">
                <div class="brand-icon"><i class="bi bi-boxes"></i></div>
                <div class="brand-text">
                    <div class="fw-bold">ERP WMS</div>
                    <div class="small text-muted">Inventory Enterprise</div>
                </div>
            </div>
            <div class="nav-menu" id="sidebarMenu"></div>
        </aside>

        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <main class="main" id="mainContent">
            <header class="topbar">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-light btn-sm sidebar-toggle" id="menuToggle" title="Toggle sidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="global-search">
                        <i class="bi bi-search"></i>
                        <input id="globalSearchInput" class="form-control" placeholder="Tìm mã hàng / serial / barcode" />
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2 ms-auto">
                    <select id="languageSelect" class="form-select form-select-sm" style="width:110px">
                        <option value="vi">VI</option>
                        <option value="en">EN</option>
                        <option value="zh">中文</option>
                    </select>
                    <button class="btn btn-light position-relative" id="btnNotifications">
                        <i class="bi bi-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-danger d-none" id="notificationCount">0</span>
                    </button>
                    <span class="badge rounded-pill text-bg-light px-3 py-2" id="currentUserBadge">...</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-light" type="submit" title="Logout"><i class="bi bi-box-arrow-right"></i></button>
                    </form>
                </div>
            </header>
            <section id="app" class="page"></section>
        </main>
    </div>

    <div class="right-drawer" id="drawer">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0">Xem nhanh hàng hóa</h5>
            <div class="d-flex justify-content-end mb-2"><button class="btn btn-outline-primary btn-sm" id="btnPrintVoucher"><i class="bi bi-printer me-1"></i><span id="btnPrintVoucherText"></span></button><button class="btn btn-light" id="btnCloseDrawer"><i class="bi bi-x-lg"></i></button></div>
        </div>
        <div id="drawerBody"></div>
    </div>

    <div class="toast-lite" id="toastLite"></div>

    <div class="swal-lite-backdrop" id="swalLite">
        <div class="swal-lite">
            <h4 class="fw-bold" id="swalTitle">Xác nhận ghi sổ</h4>
            <p class="text-muted" id="swalText">Nghiệp vụ sẽ được ghi sổ ngay.</p>
            <div class="audit-footer mb-3" id="swalSummary"></div>
            <div class="d-flex justify-content-end gap-2">
                <button class="btn btn-light" id="swalCancel">Hủy</button>
                <button class="btn btn-primary" id="swalConfirm">Xác nhận lưu & ghi sổ</button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/erp/js/core/config.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/ui.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/combobox.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/router.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/template.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/print.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/table.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/payload.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/required.js" asp-append-version="true"></script>
    <script src="~/erp/js/core/pagination.js" asp-append-version="true"></script>
    <script src="~/erp/js/models/dashboard.model.js" asp-append-version="true"></script>
    <script src="~/erp/js/models/inventory.model.js" asp-append-version="true"></script>
    <script src="~/erp/js/models/operation.model.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/dashboard.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/tracking.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/inventory.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/quantity-inventory.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/operation.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/setup.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/import.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/reports.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/pages/reconciliation.page.js" asp-append-version="true"></script>
    <script src="~/erp/js/app.js" asp-append-version="true"></script>
</body>
</html>
