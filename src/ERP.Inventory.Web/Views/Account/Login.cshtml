@model ERP.Inventory.Web.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - ERP Inventory</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { min-height: 100vh; display: grid; place-items: center; background: #f8fafc; color: #111827; }
        .login-card { width: min(420px, calc(100vw - 32px)); border: 1px solid #d1d5db; border-radius: 12px; background: #fff; box-shadow: 0 8px 24px rgba(15,23,42,.08); padding: 28px; }
        .brand-icon { width: 44px; height: 44px; border-radius: 8px; background: #1e5bff; color: #fff; display: grid; place-items: center; font-weight: 800; }
    </style>
</head>
<body>
    <main class="login-card">
        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="brand-icon">ERP</div>
            <div>
                <h1 class="h4 fw-bold mb-0">ERP Inventory</h1>
                <div class="text-muted small">Warehouse Management System</div>
            </div>
        </div>
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
            <div class="mb-3">
                <label asp-for="LanguageCode" class="form-label fw-semibold">Ngôn ngữ</label>
                <select asp-for="LanguageCode" class="form-select">
                    <option value="vi">Tiếng Việt</option>
                    <option value="en">English</option>
                    <option value="zh">中文</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="UserName" class="form-label fw-semibold">Tài khoản</label>
                <input asp-for="UserName" class="form-control" autocomplete="username" />
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Mật khẩu</label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
            </div>
            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Ghi nhớ đăng nhập</label>
            </div>
            <button class="btn btn-primary w-100" type="submit">Đăng nhập</button>
        </form>
        <div class="mt-4 small text-muted">
            @* Tài khoản mặc định: <b>admin</b>, <b>manager</b>, <b>staff</b>, <b>viewer</b>. Mật khẩu: <b>123456</b>. *@
        </div>
    </main>
</body>
</html>
